{
  "entities": {
    "User": {
      "title": "User",
      "description": "Represents an application user.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "manager", "technician", "viewer"] },
        "companyId": { "type": "string" },
        "createdAt": { "type": "timestamp" }
      },
      "required": ["uid", "email", "role", "companyId", "createdAt"]
    },
    "Company": {
      "title": "Company",
      "description": "Represents a company entity.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "siren": { "type": "string" },
        "createdAt": { "type": "timestamp" }
      },
      "required": ["name", "siren", "createdAt"]
    },
    "Site": {
      "title": "Site",
      "description": "Represents a specific establishment (Siret).",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "siret": { "type": "string" },
        "type": { "type": "string", "enum": ["ERP", "ERT"] },
        "category": { "type": "string" },
        "address": { "type": "string" },
        "createdAt": { "type": "timestamp" }
      },
      "required": ["name", "siret", "type", "createdAt"]
    },
    "Equipment": {
      "title": "Equipment",
      "description": "Represents a piece of safety equipment.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "type": { "type": "string" },
        "status": { "type": "string", "enum": ["OK", "MAINTENANCE", "HS"] },
        "brand": { "type": "string" },
        "model": { "type": "string" },
        "serialNumber": { "type": "string" },
        "location": { "type": "string" },
        "installationDate": { "type": "timestamp" },
        "companyId": { "type": "string" },
        "siteId": { "type": "string" },
        "createdAt": { "type": "timestamp" }
      },
      "required": ["name", "type", "status", "companyId", "siteId", "createdAt"]
    },
    "Intervention": {
      "title": "Intervention",
      "description": "Represents a maintenance intervention.",
      "type": "object",
      "properties": {
        "date": { "type": "timestamp" },
        "type": { "type": "string" },
        "technicianName": { "type": "string" },
        "providerName": { "type": "string" },
        "status": { "type": "string" },
        "notes": { "type": "string" },
        "companyId": { "type": "string" },
        "siteId": { "type": "string" },
        "equipmentId": { "type": "string" },
        "createdAt": { "type": "timestamp" }
      },
      "required": ["date", "type", "technicianName", "providerName", "status", "companyId", "siteId", "createdAt"]
    },
    "Anomaly": {
      "title": "Anomaly",
      "description": "Represents a reported anomaly.",
      "type": "object",
      "properties": {
        "equipmentId": { "type": "string" },
        "description": { "type": "string" },
        "severity": { "type": "string", "enum": ["observation", "danger"] },
        "status": { "type": "string", "enum": ["open", "resolved"] },
        "reportedBy": { "type": "string" },
        "date": { "type": "timestamp" },
        "companyId": { "type": "string" },
        "siteId": { "type": "string" },
        "createdAt": { "type": "timestamp" }
      },
      "required": ["description", "severity", "status", "reportedBy", "date", "companyId", "siteId", "createdAt"]
    },
    "Provider": {
      "title": "Provider",
      "description": "Represents an external service provider.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "type": { "type": "string" },
        "specialties": { "type": "array", "items": { "type": "string" } },
        "contact": { "type": "string" },
        "phone": { "type": "string" },
        "contractEnd": { "type": "string" },
        "status": { "type": "string", "enum": ["Actif", "Expiré"] },
        "createdAt": { "type": "timestamp" }
      },
      "required": ["name", "type", "createdAt"]
    },
    "Certification": {
      "title": "Certification",
      "description": "Represents an internal employee certification.",
      "type": "object",
      "properties": {
        "user": { "type": "string" },
        "role": { "type": "string" },
        "type": { "type": "string" },
        "deliveryDate": { "type": "string" },
        "expiryDate": { "type": "string" },
        "status": { "type": "string", "enum": ["Valid", "Expiring", "Expired"] },
        "createdAt": { "type": "timestamp" }
      },
      "required": ["user", "role", "type", "createdAt"]
    },
    "Event": {
      "title": "Event",
      "description": "Represents a journal event.",
      "type": "object",
      "properties": {
        "date": { "type": "timestamp" },
        "type": { "type": "string" },
        "category": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "author": { "type": "string" },
        "hash": { "type": "string" },
        "hasAttachment": { "type": "boolean" },
        "createdAt": { "type": "timestamp" }
      },
      "required": ["date", "type", "category", "title", "description", "author", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "User" },
      "description": "User document."
    },
    "/companies/{companyId}": {
      "schema": { "$ref": "Company" },
      "description": "Company document."
    },
    "/companies/{companyId}/events/{eventId}": {
      "schema": { "$ref": "Event" },
      "description": "Event document."
    },
    "/companies/{companyId}/providers/{providerId}": {
      "schema": { "$ref": "Provider" },
      "description": "Provider document."
    },
    "/companies/{companyId}/certifications/{certificationId}": {
      "schema": { "$ref": "Certification" },
      "description": "Certification document."
    },
    "/companies/{companyId}/sites/{siteId}": {
      "schema": { "$ref": "Site" },
      "description": "Site document."
    },
    "/companies/{companyId}/sites/{siteId}/equipments/{equipmentId}": {
      "schema": { "$ref": "Equipment" },
      "description": "Equipment document."
    },
    "/companies/{companyId}/sites/{siteId}/equipments/{equipmentId}/interventions/{interventionId}": {
      "schema": { "$ref": "Intervention" },
      "description": "Intervention document."
    },
    "/companies/{companyId}/sites/{siteId}/anomalies/{anomalyId}": {
      "schema": { "$ref": "Anomaly" },
      "description": "Anomaly document."
    }
  }
}
