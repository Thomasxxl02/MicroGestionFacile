{
  "entities": {
    "Company": {
      "title": "Company",
      "description": "Represents a legal entity (Siren) using the application.",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "Legal name of the company" },
        "siren": { "type": "string", "description": "9-digit Siren number" },
        "address": { "type": "string", "description": "Headquarters address" },
        "activity": { "type": "string", "description": "APE/NAF code" },
        "createdAt": { "type": "string", "format": "date-time" },
        "createdBy": { "type": "string", "description": "UID of the creator" }
      },
      "required": ["name", "siren", "createdAt"]
    },
    "User": {
      "title": "User",
      "description": "Represents a user or technician associated with a company.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "role": { "type": "string", "enum": ["admin", "manager", "technician", "viewer"] },
        "companyId": { "type": "string", "description": "Reference to the Company" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["email", "role", "companyId"]
    },
    "Site": {
      "title": "Site",
      "description": "An establishment (Siret) belonging to a company.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "siret": { "type": "string", "description": "14-digit Siret number" },
        "type": { "type": "string", "enum": ["ERP", "ERT"] },
        "erpCategory": { "type": "string", "enum": ["1", "2", "3", "4", "5"] },
        "erpType": { "type": "string" },
        "capacity": { "type": "number" },
        "address": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "siret", "type", "createdAt"]
    },
    "Equipment": {
      "title": "Equipment",
      "description": "A safety equipment (extinguisher, BAES, etc.) located on a site.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "type": { "type": "string" },
        "brand": { "type": "string" },
        "model": { "type": "string" },
        "serialNumber": { "type": "string" },
        "location": { "type": "string" },
        "status": { "type": "string", "enum": ["OK", "MAINTENANCE", "HS"] },
        "installationDate": { "type": "string", "format": "date-time" },
        "lastMaintenanceDate": { "type": "string", "format": "date-time" },
        "nextInspectionDate": { "type": "string", "format": "date-time" },
        "inspectionFrequencyMonths": { "type": "number" },
        "companyId": { "type": "string" },
        "siteId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "type", "status", "companyId", "siteId"]
    },
    "Intervention": {
      "title": "Intervention",
      "description": "A maintenance operation performed on an equipment.",
      "type": "object",
      "properties": {
        "type": { "type": "string" },
        "date": { "type": "string", "format": "date-time" },
        "technicianName": { "type": "string" },
        "providerName": { "type": "string" },
        "status": { "type": "string", "enum": ["DRAFT", "PENDING_SIGNATURE", "SIGNED"] },
        "notes": { "type": "string" },
        "signature": { "type": "string", "description": "Base64 signature image or hash" },
        "companyId": { "type": "string" },
        "siteId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["type", "date", "status", "companyId", "siteId"]
    },
    "AuditLog": {
      "title": "AuditLog",
      "description": "Immutable log of critical actions for compliance.",
      "type": "object",
      "properties": {
        "type": { "type": "string" },
        "description": { "type": "string" },
        "authorId": { "type": "string" },
        "authorName": { "type": "string" },
        "companyId": { "type": "string" },
        "metadata": { "type": "object" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["type", "description", "authorId", "companyId", "createdAt"]
    }
  },
  "firestore": {
    "/companies/{companyId}": { "schema": "Company", "description": "Company root" },
    "/users/{userId}": { "schema": "User", "description": "User profiles" },
    "/companies/{companyId}/sites/{siteId}": { "schema": "Site", "description": "Establishments" },
    "/companies/{companyId}/sites/{siteId}/equipments/{equipmentId}": { "schema": "Equipment", "description": "Safety equipment" },
    "/companies/{companyId}/sites/{siteId}/equipments/{equipmentId}/interventions/{interventionId}": { "schema": "Intervention", "description": "Maintenance history" },
    "/audit_logs/{logId}": { "schema": "AuditLog", "description": "Global audit trail" }
  }
}
